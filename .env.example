# Neon pooled URL (recommended for serverless) or any Postgres URL.
# SQLite `file:` URLs are not supported by this app.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Local Docker: postgresql://tot:tot@localhost:5432/tot

# Admin UI — set a long random password
ADMIN_PASSWORD="change-me"
# JWT signing secret (min 16 chars)
ADMIN_SECRET="change-me-to-a-long-random-string"

# Encrypt Pinterest tokens at rest (long random string, 32+ chars recommended)
TOKEN_ENCRYPTION_KEY="change-me-to-a-long-random-string"

# Vercel Cron — Authorization: Bearer <CRON_SECRET>
CRON_SECRET="change-me-for-cron-only"

# Pinterest OAuth (https://developers.pinterest.com/)
PINTEREST_APP_ID=""
PINTEREST_APP_SECRET=""
NEXT_PUBLIC_PINTEREST_APP_ID=""
# Rare: only if OAuth callback gets wrong Host / redirect_uri (proxy bug). Normally omit —
# redirect URI is derived from the request (and VERCEL_URL on Vercel). Do not set for preview
# deploys if you want each *.vercel.app host to work (after registering each in Pinterest).
NEXT_PUBLIC_APP_URL=""

# Google Sign-In (admin) — same OAuth client ID on client + server
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""
# Comma-separated emails allowed to sign in with Google (must match)
GOOGLE_ALLOWED_EMAILS="you@gmail.com"
