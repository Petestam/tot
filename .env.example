# Local dev (SQLite — no Docker needed):
# DATABASE_URL="file:./prisma/dev.db"
# Production (Postgres — change prisma/schema.prisma provider to "postgresql"):
DATABASE_URL="file:./prisma/dev.db"

# Admin UI — set a long random password
ADMIN_PASSWORD="change-me"
# JWT signing secret (min 16 chars)
ADMIN_SECRET="change-me-to-a-long-random-string"

# Encrypt Pinterest tokens at rest (long random string, 32+ chars recommended)
TOKEN_ENCRYPTION_KEY="change-me-to-a-long-random-string"

# Vercel Cron — Authorization: Bearer <CRON_SECRET>
CRON_SECRET="change-me-for-cron-only"

# Pinterest OAuth (https://developers.pinterest.com/)
PINTEREST_APP_ID=""
PINTEREST_APP_SECRET=""
NEXT_PUBLIC_PINTEREST_APP_ID=""

# Google Sign-In (admin) — same OAuth client ID on client + server
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""
# Comma-separated emails allowed to sign in with Google (must match)
GOOGLE_ALLOWED_EMAILS="you@gmail.com"
